# Required — Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional — set to "true" to expose /test-registration on a production build (default: off)
# VITE_ENABLE_TEST_REGISTRATION=true

# Set in Supabase Dashboard → Edge Functions → Secrets (not in this file):
# ADMIN_SESSION_SECRET (min 16 chars), SUPABASE_SERVICE_ROLE_KEY (auto), FRONTEND_URL,
# PAYMENT_CALLBACK_URL (optional), RESEND_API_KEY / RESEND_FROM (optional, for confirmation email)
#
# Payment — ICICI Eazypay (INR only):
#   ICICI_EAZYPAY_MERCHANT_ID, ICICI_EAZYPAY_AES_KEY (16-char AES key from bank),
#   optional: ICICI_EAZYPAY_SUB_MERCHANT_ID, ICICI_EAZYPAY_PAYMODE,
#   ICICI_EAZYPAY_BASE_URL — only if the bank gives a different ICICI checkout URL; must be *.icicibank.com
#     (NOT your site — return/callback is FRONTEND_URL + /payment-callback or PAYMENT_CALLBACK_URL),
#   ICICI_EAZYPAY_OPTIONAL_FIELDS (pipe-separated, if required by bank)
